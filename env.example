# Telegram API credentials (my.telegram.org)
API_ID=123456
API_HASH=your_api_hash_here

# Bot that receives owner commands (BotFather token)
BOT_TOKEN=123456:your-bot-token

# Only this Telegram user id may control the bot
OWNER_ID=123456789

# Pyrogram string session for the assistant account that joins voice chats
STRING_SESSION=your_pyrogram_string_session

# Group whose Voice Chat is used to (optionally) archive recordings
RECORD_GROUP=-1001111111111

# Group whose Voice Chat is captured as the live audio source
LOGGER_GROUP=-1002222222222

# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=vc_forward_bot

# Name of the PulseAudio null-sink used to bridge the two calls.
# Created automatically at startup, override only if you already
# manage PulseAudio sinks yourself.
PULSE_SINK_NAME=vcrelay

# Directory used for named pipes / temporary recordings
WORK_DIR=/tmp/vc_forward_bot
